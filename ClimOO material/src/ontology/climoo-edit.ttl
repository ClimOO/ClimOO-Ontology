###  https://www.w3id.org/climoo#ClimOO_0000113
:ClimOO_0000113 rdf:type owl:Class ;
                owl:equivalentClass [ owl:intersectionOf ( <http://purl.obolibrary.org/obo/ENVO_06105015>
                                                           [ rdf:type owl:Restriction ;

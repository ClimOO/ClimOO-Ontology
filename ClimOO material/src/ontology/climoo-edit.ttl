:ClimOO_0000225 rdf:type owl:Class ;
                rdfs:subClassOf <http://purl.obolibrary.org/obo/BFO_0000015> ;
                rdfs:comment """This class is just for grouping purposes and must not be used for annotation. For clarifications, see comments to EnvO “material transformation process” class. http://purl.obolibrary.org/obo/ENVO_03000043 

This class could be implement to track transformation processes broadly understood if needed."""@en ;
                rdfs:label "transformation process"@en ;
                <https://spec.industrialontologies.org/ontology/core/meta/AnnotationVocabulary/maturity> <https://spec.industrialontologies.org/ontology/core/meta/AnnotationVocabulary/Provisional> .


###  https://www.w3id.org/climoo#ClimOO_0000226
:ClimOO_0000226 rdf:type owl:Class ;
                rdfs:subClassOf <http://purl.obolibrary.org/obo/ENVO_01000993> ,
                                [ owl:intersectionOf ( [ rdf:type owl:Restriction ;
                                                         owl:onProperty <http://purl.obolibrary.org/obo/RO_0004008> ;
                                                         owl:someValuesFrom :ClimOO_0000153

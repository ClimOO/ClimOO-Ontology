   owl:annotatedSource <http://purl.obolibrary.org/obo/ENVO_01000944> ;
   owl:annotatedProperty <http://www.w3.org/2004/02/skos/core#definition> ;
   owl:annotatedTarget """Revised definition for ClimOO Ontology:
A plastic debris particle that is between 1 µm and 5 mm in its largest dimension."""@en ;
   rdfs:comment "We included a lower-level threshold to completely define this class. We follow Hartmann et al. (2019)'s recommendations."@en ;
   <https://www.w3id.org/sco#SCO_0000039> :ClimOO_0000073
 ] .



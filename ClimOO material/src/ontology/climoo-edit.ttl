                rdfs:subClassOf <http://purl.obolibrary.org/obo/ENVO_06105105> ;
                <http://www.geneontology.org/formats/oboInOwl#hasBroadSynonym> "synthetic polymer debris, submicronparticle"@en ;
                <http://www.geneontology.org/formats/oboInOwl#hasExactSynonym> "submicronplastic debris, submicronplastic litter"@en ;
                rdfs:label "submicron plastic debris particle"@en ;
                <http://www.w3.org/2004/02/skos/core#definition> "A nanoplastic particle that is between 100 and 1000 nm in its largest dimension."@en ;
                <https://spec.industrialontologies.org/ontology/core/meta/AnnotationVocabulary/maturity> <https://spec.industrialontologies.org/ontology/core/meta/AnnotationVocabulary/Released> .



                                    ] ;
                rdfs:subClassOf <http://purl.obolibrary.org/obo/BFO_0000027> ,
                                [ rdf:type owl:Restriction ;
                                  owl:onProperty <http://purl.obolibrary.org/obo/BFO_0000172> ;
                                  owl:someValuesFrom :ClimOO_0000163
                                ] ;
                <http://www.geneontology.org/formats/oboInOwl#hasExactSynonym> "plastic debris agglomerate"@en ;
                rdfs:comment "References to plastic debris aggregate formation and participation in pollution processes can be added as needed." ;
                rdfs:label "plastic debris aggregate"@en ;
                <http://www.w3.org/2004/02/skos/core#definition> "An aggregate that has member part at least a plastic debris."@en ;
                <https://spec.industrialontologies.org/ontology/core/meta/AnnotationVocabulary/maturity> <https://spec.industrialontologies.org/ontology/core/meta/AnnotationVocabulary/Released> ;
                <https://www.w3id.org/sco#SCO_0000039> :ClimOO_0000072 ,
                                                       :ClimOO_0000073 ,
                                                       :ClimOO_0000074 ,
                                                       :ClimOO_0000075 ,

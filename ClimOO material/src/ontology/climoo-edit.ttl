###  https://www.w3id.org/climoo#ClimOO_0000177
:ClimOO_0000177 rdf:type owl:Class ;
                rdfs:subClassOf :ClimOO_0000163 ,
                                [ rdf:type owl:Restriction ;
                                  owl:onProperty <http://purl.obolibrary.org/obo/BFO_0000110> ;
                                  owl:someValuesFrom <http://purl.obolibrary.org/obo/ENVO_06105112>
                                ] ;
                rdfs:label "plastic surface coating debris particle"@en ;
                <http://www.w3.org/2004/02/skos/core#definition> "A debris particle of polymer composite-based synthetic material that is or derives from some plastic-based surface coatings, such as paints, and has been released into some environmental material."@en ;
                <https://spec.industrialontologies.org/ontology/core/meta/AnnotationVocabulary/maturity> <https://spec.industrialontologies.org/ontology/core/meta/AnnotationVocabulary/Released> .


###  https://www.w3id.org/climoo#ClimOO_0000178
:ClimOO_0000178 rdf:type owl:Class ;
                rdfs:subClassOf <http://purl.obolibrary.org/obo/ENVO_01000993> ,
                                [ owl:intersectionOf ( :ClimOO_0000225
                                                       [ rdf:type owl:Restriction ;
                                                         owl:onProperty <http://purl.obolibrary.org/obo/RO_0002233> ;
                                                         owl:someValuesFrom [ rdf:type owl:Class ;
                                                                              owl:unionOf ( <http://purl.obolibrary.org/obo/ENVO_01000776>
                                                                                            [ owl:intersectionOf ( <http://purl.obolibrary.org/obo/ENVO_01000776>
                                                                                                                   [ rdf:type owl:Restriction ;
                                                                                                                     owl:onProperty <http://purl.obolibrary.org/obo/RO_0000087> ;
                                                                                                                     owl:someValuesFrom <http://purl.obolibrary.org/obo/ENVO_01000665>
                                                                                                                   ]
                                                                                                                 ) ;
                                                                                              rdf:type owl:Class
                                                                                            ]
                                                                                          )
                                                                            ]
                                                       ]
                                                     ) ;
                                  rdf:type owl:Class
                                ] ;
                rdfs:comment "Currently, the ClimOO Ontology imports EnvO representation of wastes and includes a class for plastic upcycling. This is adequate for current ontology purposes. Given the strict interconnection between upcycling and recycling processes, however, we envision discussions with subject matter expert for possible implementations."@en ;
                rdfs:label "plastic upcycling process"@en ;
                <http://www.w3.org/2004/02/skos/core#definition> "A material transformation process that has as an input some piece of synthetic plastic or corresponding waste, as output, some material entity(-ies) in which a higher value is inhered (compared to that inheriting into the plastic input), according to some stakeholder perspective."@en ;
                <https://spec.industrialontologies.org/ontology/core/meta/AnnotationVocabulary/maturity> <https://spec.industrialontologies.org/ontology/core/meta/AnnotationVocabulary/Released> .

[ rdf:type owl:Axiom ;
   owl:annotatedSource :ClimOO_0000178 ;
   owl:annotatedProperty rdfs:comment ;
   owl:annotatedTarget "Currently, the ClimOO Ontology imports EnvO representation of wastes and includes a class for plastic upcycling. This is adequate for current ontology purposes. Given the strict interconnection between upcycling and recycling processes, however, we envision discussions with subject matter expert for possible implementations."@en ;
   rdfs:comment "For insights on ongoing conversations on these topics see the “Food, Waste, and Sustainability: Synergizing Ontology Efforts” workshop at ICBO2025 https://sites.google.com/view/fws2025workshop/home-page"@en ;
   rdfs:seeAlso <http://purl.obolibrary.org/obo/ENVO_01000741>
 ] .


###  https://www.w3id.org/climoo#ClimOO_0000179
:ClimOO_0000179 rdf:type owl:Class ;
                rdfs:subClassOf <http://purl.obolibrary.org/obo/ENVO_02000178> ,
                                _:genid1536 ;
                rdfs:label "pollution prevention"@en ;
                <http://www.w3.org/2004/02/skos/core#definition> "An anthropogenic modulation of pollution that leads to avoiding the release of pollutants in an environmental material, according to some stakeholder goals and perspectives."@en ;
                <https://spec.industrialontologies.org/ontology/core/meta/AnnotationVocabulary/maturity> <https://spec.industrialontologies.org/ontology/core/meta/AnnotationVocabulary/Released> .

_:genid1536 rdf:type owl:Restriction ;
             owl:onProperty <http://purl.obolibrary.org/obo/RO_0002212> ;
             owl:someValuesFrom <http://purl.obolibrary.org/obo/ENVO_02500036> .

[ rdf:type owl:Axiom ;
   owl:annotatedSource :ClimOO_0000179 ;
   owl:annotatedProperty rdfs:subClassOf ;
   owl:annotatedTarget _:genid1536 ;
   rdfs:comment "Currently, the axiomatization of this class covers reference to the RO “negatively regulates” object property. Revisions may provide this axiom with more specific and suitable object properties."@en
 ] .


###  https://www.w3id.org/climoo#ClimOO_0000180
:ClimOO_0000180 rdf:type owl:Class ;
                rdfs:subClassOf <http://purl.obolibrary.org/obo/ENVO_06105014> ,
                                [ owl:intersectionOf ( <http://purl.obolibrary.org/obo/ENVO_06105014>
                                                       [ rdf:type owl:Restriction ;
                                                         owl:onProperty <http://purl.obolibrary.org/obo/RO_0002233> ;
                                                         owl:someValuesFrom :ClimOO_0000109
                                                       ]
                                                     ) ;
                                  rdf:type owl:Class
                                ] ;
                rdfs:comment """Definitions of plastic properties, such as biodegradability and composability, and related processes, currently covered in the ClimOO Ontology, refer to existing policy standards. This aims to stress the significance of such regulations concerning defining such entities and, especially, the consequences in terms of pollution and sustainability interventions.

It is noteworthy to mention that such standards present limitations. See, for instance, the work of Rayns et al. (2021), Steiner et al. (2022, 2024), concerning plastic biodegradability.

We envision implementing such definitions in accordance with regulation revisions and novel research findings."""@en ;
                rdfs:label "polymer biodegradation"@en ;
                <http://www.w3.org/2004/02/skos/core#definition> "A biodegradation process that applies to some polymers (biodegradable polymers)."@en ;
                <https://spec.industrialontologies.org/ontology/core/meta/AnnotationVocabulary/maturity> <https://spec.industrialontologies.org/ontology/core/meta/AnnotationVocabulary/Released> ;
                <https://www.w3id.org/sco#SCO_0000039> :ClimOO_0000072 ,
                                                       :ClimOO_0000073 ,
                                                       :ClimOO_0000074 ,
                                                       :ClimOO_0000075 ,
                                                       :ClimOO_0000228 .



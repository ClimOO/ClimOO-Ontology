                                                                                 owl:someValuesFrom [ rdf:type owl:Class ;
                                                                                                      owl:unionOf ( <http://purl.obolibrary.org/obo/ENVO_01000313>
                                                                                                                    :ClimOO_0000071
                                                                                                                  )
                                                                                                    ]
                                                                               ]
                                                                             )

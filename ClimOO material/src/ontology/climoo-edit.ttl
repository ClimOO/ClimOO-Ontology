:ClimOO_0000181 rdf:type owl:Class ;
                rdfs:subClassOf :ClimOO_0000211 ;
                rdfs:label "polymer composite-based synthetic material"@en ;
                <http://www.w3.org/2004/02/skos/core#definition> "A synthetic polymer-based material that incorporates non-polymeric molecules as reinforcement within the polymer matrix."@en ;
                <https://spec.industrialontologies.org/ontology/core/meta/AnnotationVocabulary/maturity> <https://spec.industrialontologies.org/ontology/core/meta/AnnotationVocabulary/Released> .


###  https://www.w3id.org/climoo#ClimOO_0000182
:ClimOO_0000182 rdf:type owl:Class ;
                rdfs:subClassOf :ClimOO_0000225 ,
                                [ owl:intersectionOf ( [ rdf:type owl:Restriction ;
                                                         owl:onProperty <http://purl.obolibrary.org/obo/RO_0004008> ;

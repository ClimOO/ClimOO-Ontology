                                  owl:someValuesFrom :ClimOO_0000168
                                ] ;
                rdfs:comment "Reference to (bio)mineralization of polymers constituting synthetic polymer-based materials and pieces of plastics/synthetic polymer-based materials can be included as needed."@en ;
                rdfs:label "plastic mineralization process"@en ;
                <http://www.w3.org/2004/02/skos/core#definition> "A mineralization process that applies to some polymers constituting some plastic."@en ;
                <https://spec.industrialontologies.org/ontology/core/meta/AnnotationVocabulary/maturity> <https://spec.industrialontologies.org/ontology/core/meta/AnnotationVocabulary/Released> .



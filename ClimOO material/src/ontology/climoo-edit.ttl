                                                       ]
                                                     ) ;
                                  rdf:type owl:Class
                                ] ,
                                _:genid1844 ;
                rdfs:comment "To date, the ClimOO Ontology does not cover related classes for synthetic polymer-based materials, as out of the current scope. Implementations can go in this direction if needed."@en ;
                rdfs:label "production process of a piece of synthetic plastic"@en ;
                <http://www.w3.org/2004/02/skos/core#definition> "A manufacturing process that has some synthetic plastic as the main input and some piece of synthetic plastic as the main output." ;
                <https://spec.industrialontologies.org/ontology/core/meta/AnnotationVocabulary/maturity> <https://spec.industrialontologies.org/ontology/core/meta/AnnotationVocabulary/Released> .

_:genid1844 rdf:type owl:Restriction ;

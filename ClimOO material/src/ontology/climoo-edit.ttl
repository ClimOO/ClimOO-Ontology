           owl:onProperty <http://purl.obolibrary.org/obo/BFO_0000178> ;
           owl:someValuesFrom [ owl:intersectionOf ( <http://purl.obolibrary.org/obo/BFO_0000146>
                                                     [ rdf:type owl:Restriction ;
                                                       owl:onProperty <http://purl.obolibrary.org/obo/RO_0000086> ;
                                                       owl:someValuesFrom <http://purl.obolibrary.org/obo/PATO_0001665>
                                                     ]
                                                   ) ;
                                rdf:type owl:Class
                              ] .


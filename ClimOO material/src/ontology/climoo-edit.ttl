###  https://www.w3id.org/climoo#ClimOO_0000210
:ClimOO_0000210 rdf:type owl:Class ;
                owl:equivalentClass [ owl:intersectionOf ( <http://purl.obolibrary.org/obo/CHEBI_60027>
                                                           [ rdf:type owl:Restriction ;
                                                             owl:onProperty <http://purl.obolibrary.org/obo/RO_0002353> ;
                                                             owl:someValuesFrom :ClimOO_0000227
                                                           ]
                                                         ) ;
                                      rdf:type owl:Class
                                    ] ;
                rdfs:subClassOf <http://purl.obolibrary.org/obo/CHEBI_60027> ,
                                [ owl:intersectionOf ( <http://purl.obolibrary.org/obo/ENVO_00003074>
                                                       [ rdf:type owl:Restriction ;
                                                         owl:onProperty <http://purl.obolibrary.org/obo/RO_0002353> ;
                                                         owl:someValuesFrom :ClimOO_0000227
                                                       ]
                                                     ) ;
                                  rdf:type owl:Class
                                ] ;
                <http://www.geneontology.org/formats/oboInOwl#hasExactSynonym> "artificial polymer"@en ;
                rdfs:comment "References to natural polymers can be added as needed."@en ;
                rdfs:label "synthetic polymer"@en ;
                <http://www.w3.org/2004/02/skos/core#definition> "A polymer that is a direct outcome of a human-driven manufacturing process."@en ;
                <https://spec.industrialontologies.org/ontology/core/meta/AnnotationVocabulary/maturity> <https://spec.industrialontologies.org/ontology/core/meta/AnnotationVocabulary/Released> .


###  https://www.w3id.org/climoo#ClimOO_0000211
:ClimOO_0000211 rdf:type owl:Class ;
                rdfs:subClassOf <http://purl.obolibrary.org/obo/ENVO_00003074> ,
                                [ owl:intersectionOf ( <http://purl.obolibrary.org/obo/ENVO_00010483>
                                                       [ rdf:type owl:Restriction ;
                                                         owl:onProperty <http://purl.obolibrary.org/obo/RO_0000086> ;
                                                         owl:someValuesFrom <http://purl.obolibrary.org/obo/PATO_0000117>
                                                       ]
                                                       [ rdf:type owl:Restriction ;
                                                         owl:onProperty <http://purl.obolibrary.org/obo/RO_0000086> ;
                                                         owl:someValuesFrom [ rdf:type owl:Class ;
                                                                              owl:unionOf ( <http://purl.obolibrary.org/obo/PATO_0000141>
                                                                                            <http://purl.obolibrary.org/obo/PATO_0001332>
                                                                                          )
                                                                            ]
                                                       ]
                                                     ) ;
                                  rdf:type owl:Class
                                ] ,
                                _:genid1783 ,
                                _:genid1785 ;
                rdfs:comment "From a material science perspective (which is the one we have to refer to for classifying plastics and polymers) plastic materials are constituted by polymers that are thermosetting and thermoplastic, and not, for instance, by elastic polymers. There exist, however, some synthetic combinations, such as thermoplastic elastomer-based synthetic materials, that are composed by polymers presenting both elastic and plastic properties. Strictly speaking, the last are not plastics (material science perspective). However, these materials are included in the count of debris (from an environmental perspective which is the one we have to refer to for classifying debris and pollution). So, the ClimOO Ontology accounts for these two perspectives, modeling differences and interconnection."@en ,
                             "Implementations require to address references to composition threshold. We envision discussion with subject matter experts."@en ;
                rdfs:label "synthetic polymer-based material"@en ;
                <http://www.w3.org/2004/02/skos/core#definition> "A manufactured material that is mainly composed of some synthetic polymers and is an output of a manufacturing process of synthetic polymer-based material. Synthetic polymers constitute the material matrix (frame)."@en ;
                <https://spec.industrialontologies.org/ontology/core/meta/AnnotationVocabulary/maturity> <https://spec.industrialontologies.org/ontology/core/meta/AnnotationVocabulary/Released> .

_:genid1783 rdf:type owl:Restriction ;
             owl:onProperty <http://purl.obolibrary.org/obo/BFO_0000110> ;
             owl:someValuesFrom :ClimOO_0000210 .

_:genid1785 rdf:type owl:Restriction ;
             owl:onProperty <http://purl.obolibrary.org/obo/RO_0000086> ;
             owl:someValuesFrom <http://purl.obolibrary.org/obo/PATO_0000125> .

[ rdf:type owl:Axiom ;
   owl:annotatedSource :ClimOO_0000211 ;
   owl:annotatedProperty rdfs:subClassOf ;
   owl:annotatedTarget _:genid1783 ;
   rdfs:comment "BFO “continuant part” is not a transitive object property. User may incorporate transitivity to specify the chain of composition between polymers, plastic/polymers-based material, and related pieces and objects of plastic/polymers-based material, as needed."@en
 ] .

[ rdf:type owl:Axiom ;
   owl:annotatedSource :ClimOO_0000211 ;
   owl:annotatedProperty rdfs:subClassOf ;
   owl:annotatedTarget _:genid1785 ;
   rdfs:comment """ClimOO Ontology developer comment:
Reference to weight can be added as needed."""@en
 ] .


###  https://www.w3id.org/climoo#ClimOO_0000212
:ClimOO_0000212 rdf:type owl:Class ;
                rdfs:subClassOf <http://purl.obolibrary.org/obo/CHEBI_23367> ,
                                [ owl:intersectionOf ( <http://purl.obolibrary.org/obo/BFO_0000030>
                                                       [ rdf:type owl:Restriction ;
                                                         owl:onProperty <http://purl.obolibrary.org/obo/BFO_0000176> ;
                                                         owl:someValuesFrom :ClimOO_0000211
                                                       ]
                                                       [ rdf:type owl:Restriction ;
                                                         owl:onProperty <http://purl.obolibrary.org/obo/RO_0000087> ;
                                                         owl:someValuesFrom :ClimOO_0000213
                                                       ]
                                                     ) ;
                                  rdf:type owl:Class
                                ] ;
                rdfs:comment "Here, we aim to track molecules that have already been added to polymers to obtain (plastic) polymer materials, not molecules that will be added. Currently, the ClimOO ontology does not intend such molecules to be already additive. Revisions can implement the ClimOO Ontology representation in this sense."@en ;
                rdfs:label "synthetic polymer-based material additive"@en ;
                <http://www.w3.org/2004/02/skos/core#definition> "A molecule with a synthetic polymer-based material additive role."@en ;
                <https://spec.industrialontologies.org/ontology/core/meta/AnnotationVocabulary/maturity> <https://spec.industrialontologies.org/ontology/core/meta/AnnotationVocabulary/Released> .


###  https://www.w3id.org/climoo#ClimOO_0000213
:ClimOO_0000213 rdf:type owl:Class ;
                rdfs:subClassOf <http://purl.obolibrary.org/obo/BFO_0000023> ;
                <http://purl.org/dc/terms/source> "References to additive incorporation, such as chemical binding or juxtaposition, can be added as needed."@en ,
                                                  "http://purl.allotrope.org/ontologies/role#AFRL_0000216" ;
                rdfs:label "synthetic polymer-based material additive role"@en ;
                <http://www.w3.org/2004/02/skos/core#definition> "A role that is realized in a molecule when it is added to some synthetic polymers to obtain a synthetic polymer-based material whose properties are modified (generally, enhanced) to fulfill the purposes of some stakeholders. Considering plastics, examples of additives include plasticizers, stabilizers, flame retardants, flow modifiers, processing aids, impact modifiers, antioxidants, pigments, biocides, and fragrances."@en ;
                <https://spec.industrialontologies.org/ontology/core/meta/AnnotationVocabulary/maturity> <https://spec.industrialontologies.org/ontology/core/meta/AnnotationVocabulary/Released> ;
                <https://www.w3id.org/sco#SCO_0000039> :ClimOO_0000072 ,
                                                       :ClimOO_0000073 ,
                                                       :ClimOO_0000074 ,
                                                       :ClimOO_0000075 ,
                                                       :ClimOO_0000228 .


###  https://www.w3id.org/climoo#ClimOO_0000214
:ClimOO_0000214 rdf:type owl:Class ;
                rdfs:subClassOf <http://purl.obolibrary.org/obo/ENVO_03000010> ,
                                _:genid1793 ;
                <http://purl.org/dc/terms/source> "Fu, L., Li, J., Wang, G., Luan, Y., & Dai, W. (2021). Adsorption behavior of organic pollutants on microplastics. Ecotoxicology and Environmental Safety, 217, 112207. https://doi.org/10.1016/j.ecoenv.2021.112207" ;
                rdfs:comment "Reference to specific types of sorption, such as absorption and adsorption, can be added as needed."@en ,
                             """Implementations will consider extending this representation to model the relation with environmental pollution as well.
According to the current axiomatization and definition, this class may be a subclass of the “environmental pollution” class. However, this seems a little bit counterintuitive.""" ;
                rdfs:label "synthetic polymer-based material sorption of pollutants"@en ;
                <http://www.w3.org/2004/02/skos/core#definition> "A material transport process that has as output some synthetic polymer-based material with an increased level of pollutants as part (compared to levels prior to participating in that process). Pollutants can both penetrate the material matrix (absorption) or remain confined on its surface (adsorption). This process generally concerns plastic materials composing plastic debris and litter."@en ;
                <https://spec.industrialontologies.org/ontology/core/meta/AnnotationVocabulary/maturity> <https://spec.industrialontologies.org/ontology/core/meta/AnnotationVocabulary/Released> ;
                <https://www.w3id.org/sco#SCO_0000039> :ClimOO_0000072 ,
                                                       :ClimOO_0000073 ,
                                                       :ClimOO_0000074 ,
                                                       :ClimOO_0000075 ,
                                                       :ClimOO_0000228 .


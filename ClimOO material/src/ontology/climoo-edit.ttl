###  https://www.w3id.org/climoo#ClimOO_0000124
:ClimOO_0000124 rdf:type owl:Class ;
                rdfs:subClassOf <http://purl.obolibrary.org/obo/BFO_0000016> ;
                rdfs:comment "References to processes realizing this disposition can be added as needed."@en ;
                rdfs:label "elasticity"@en ;
                <http://www.w3.org/2004/02/skos/core#definition> "A disposition whose realization leads the bearer to recover its size and shape after deformation."@en ;

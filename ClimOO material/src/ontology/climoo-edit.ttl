###  https://www.w3id.org/climoo#ClimOO_0000218
:ClimOO_0000218 rdf:type owl:Class ;
                rdfs:subClassOf <http://purl.obolibrary.org/obo/CHEBI_60027> ,
                                [ rdf:type owl:Restriction ;

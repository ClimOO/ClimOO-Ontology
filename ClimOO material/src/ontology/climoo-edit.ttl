                                                                              rdf:type owl:Class
                                                                            ]
                                                       ]
                                                     ) ;
                                  rdf:type owl:Class
                                ] ;
                rdfs:label "biodegradation of synthetic plastic"@en ;
                <http://www.w3.org/2004/02/skos/core#definition> "A biodegradation of plastic that applies to some synthetic polymers, constituting some synthetic plastic (biodegradable synthetic plastic). Packaging applications: 90% of the total polymer molecular weight must be degraded till mineralization into H2O, CO2, and mineral salts, in the presence of oxygen, and methane, H2O, CO2, and mineral salts, in the absence of oxygen, within the first 6 months (according to EU EN 13432, standardized laboratory test conditions). (See EU EN 13432, UNI EN ISO 20200, and Regulation - 2023/2055 - EN - EUR-Lex)."@en ;
                <https://spec.industrialontologies.org/ontology/core/meta/AnnotationVocabulary/maturity> <https://spec.industrialontologies.org/ontology/core/meta/AnnotationVocabulary/Released> .


###  https://www.w3id.org/climoo#ClimOO_0000114
:ClimOO_0000114 rdf:type owl:Class ;

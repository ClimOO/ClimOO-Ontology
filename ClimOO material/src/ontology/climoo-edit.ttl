###  https://www.w3id.org/climoo#ClimOO_0000079
:ClimOO_0000079 rdf:type owl:Class ;
                rdfs:subClassOf <http://purl.obolibrary.org/obo/ENVO_00000077> ,
                                [ rdf:type owl:Restriction ;
                                  owl:onProperty :ClimOO_0000076 ;
                                  owl:someValuesFrom <https://w3id.org/sumso#SuMSO_0000004>
                                ] ;
                owl:disjointWith :ClimOO_0000084 ;
                rdfs:comment """The terms “food system”, “agricultural system”, and “agrifood system” are often used slightly interchangeably. Here, for ClimOO ontology purposes, we use these terms as follows. A food system is a complex system dedicated to food for humans. An agricultural system is a complex system dedicated to agriculture. An agrifood system is an agricultural system that is specifically dedicated to food production for humans. Not all agricultural systems are dedicated to food production for humans. Some are, for instance, dedicated to food production for animals. Not all food systems include agricultural activities. 
We envision discussions with subject matter experts."""@en ;
                rdfs:label "agrifood system"@en ;
                <http://www.w3.org/2004/02/skos/core#definition> "An agricultural ecosystem dedicated to food production for humans."@en ;
                <https://spec.industrialontologies.org/ontology/core/meta/AnnotationVocabulary/maturity> <https://spec.industrialontologies.org/ontology/core/meta/AnnotationVocabulary/Released> .

[ rdf:type owl:Axiom ;
   owl:annotatedSource :ClimOO_0000079 ;
   owl:annotatedProperty <http://www.w3.org/2004/02/skos/core#definition> ;
   owl:annotatedTarget "An agricultural ecosystem dedicated to food production for humans."@en ;
   <https://spec.industrialontologies.org/ontology/core/meta/AnnotationVocabulary/maturity> <https://spec.industrialontologies.org/ontology/core/meta/AnnotationVocabulary/Provisional>
 ] .



[ rdf:type owl:Axiom ;
   owl:annotatedSource :ClimOO_0000163 ;
   owl:annotatedProperty owl:equivalentClass ;
   owl:annotatedTarget _:genid1356 ;
   rdfs:comment "Plastic debris refers to any piece of synthetic polymer-based material that has already been released into an environment. Thus, it is part of that environment."@en ;
   <https://www.w3id.org/sco#SCO_0000039> :ClimOO_0000073
 ] .

[ rdf:type owl:Axiom ;
   owl:annotatedSource :ClimOO_0000163 ;
   owl:annotatedProperty rdfs:subClassOf ;
   owl:annotatedTarget _:genid1378 ;
   rdfs:comment "Ontology implementations can extend the modelling of environmental persistence concerning pieces and materials made of plastics and synthetic polymers."@en
 ] .


###  https://www.w3id.org/climoo#ClimOO_0000164
:ClimOO_0000164 rdf:type owl:Class ;
                owl:equivalentClass [ owl:intersectionOf ( <http://purl.obolibrary.org/obo/ENVO_00010483>
                                                           [ rdf:type owl:Restriction ;
                                                             owl:onProperty <http://purl.obolibrary.org/obo/RO_0000087> ;
                                                             owl:someValuesFrom :ClimOO_0000165
                                                           ]
                                                         ) ;
                                      rdf:type owl:Class
                                    ] ;
                rdfs:subClassOf <http://purl.obolibrary.org/obo/ENVO_00010483> ;
                rdfs:label "plastic debris sink"@en ;
                <http://www.w3.org/2004/02/skos/core#definition> "An environmental material  with a plastic debris sink role."@en ;
                <https://spec.industrialontologies.org/ontology/core/meta/AnnotationVocabulary/maturity> <https://spec.industrialontologies.org/ontology/core/meta/AnnotationVocabulary/Released> .


###  https://www.w3id.org/climoo#ClimOO_0000165
:ClimOO_0000165 rdf:type owl:Class ;
                rdfs:subClassOf <http://purl.obolibrary.org/obo/BFO_0000023> ;
                rdfs:label "plastic debris sink role"@en ;
                <http://www.w3.org/2004/02/skos/core#definition> "A role that inheres in an environmental material (no plastics or polymer-based synthetic material) that participates in a plastic pollution process resulting in having, as an output, that environmental material with an increased level of plastic debris particles as part (compared to levels prior to participating in that process)."@en ;
                <https://spec.industrialontologies.org/ontology/core/meta/AnnotationVocabulary/maturity> <https://spec.industrialontologies.org/ontology/core/meta/AnnotationVocabulary/Released> .


###  https://www.w3id.org/climoo#ClimOO_0000166
:ClimOO_0000166 rdf:type owl:Class ;
                owl:equivalentClass [ owl:intersectionOf ( <http://purl.obolibrary.org/obo/ENVO_01001686>
                                                           [ rdf:type owl:Restriction ;
                                                             owl:onProperty <http://purl.obolibrary.org/obo/BFO_0000178> ;
                                                             owl:someValuesFrom :ClimOO_0000150
                                                           ]
                                                           [ rdf:type owl:Restriction ;
                                                             owl:onProperty <http://purl.obolibrary.org/obo/RO_0000087> ;
                                                             owl:someValuesFrom :ClimOO_0000167
                                                           ]
                                                         ) ;
                                      rdf:type owl:Class
                                    ] ;
                rdfs:subClassOf <http://purl.obolibrary.org/obo/ENVO_01001686> ;
                rdfs:comment "From a material science perspective (which is the one we have to refer to for classifying plastics and polymers) plastic materials are constituted by polymers that are thermosetting and thermoplastic, and not, for instance, by elastic polymers. There exist, however, some synthetic combinations, such as thermoplastic elastomer-based synthetic materials, that are composed by polymers presenting both elastic and plastic properties. Strictly speaking, the last are not plastics (material science perspective). However, these materials are included in the count of debris (from an environmental perspective which is the one we have to refer to for classifying debris and pollution). So, the ClimOO Ontology accounts for these two perspectives, modeling differences and interconnection."@en ;
                rdfs:label "plastic debris source"@en ;
                <http://www.w3.org/2004/02/skos/core#definition> "An a mass of environmental material  that has, as part, some polymer-based synthetic material and bears some plastic debris source role. It is generally a piece of synthetic plastic, especially plastic objects."@en ;
                <https://spec.industrialontologies.org/ontology/core/meta/AnnotationVocabulary/maturity> <https://spec.industrialontologies.org/ontology/core/meta/AnnotationVocabulary/Released> .


###  https://www.w3id.org/climoo#ClimOO_0000167
:ClimOO_0000167 rdf:type owl:Class ;
                rdfs:subClassOf <http://purl.obolibrary.org/obo/BFO_0000023> ;
                rdfs:label "plastic debris source role"@en ;
                <http://www.w3.org/2004/02/skos/core#definition> "A role that inheres in an environmental material having, as part, some polymer-based synthetic material that participates in a plastic pollution process resulting in having, as an output, an environmental material (different from that environmental material) with increased levels of plastic debris particles as part (compared to levels prior to participating in that process)."@en ;
                <https://spec.industrialontologies.org/ontology/core/meta/AnnotationVocabulary/maturity> <https://spec.industrialontologies.org/ontology/core/meta/AnnotationVocabulary/Released> .


###  https://www.w3id.org/climoo#ClimOO_0000168
:ClimOO_0000168 rdf:type owl:Class ;
                rdfs:subClassOf :ClimOO_0000225 ,
                                [ owl:intersectionOf ( :ClimOO_0000225
                                                       [ rdf:type owl:Restriction ;
                                                         owl:onProperty <http://purl.obolibrary.org/obo/RO_0002233> ;
                                                         owl:someValuesFrom [ owl:intersectionOf ( <http://purl.obolibrary.org/obo/CHEBI_60027>
                                                                                                   [ rdf:type owl:Restriction ;
                                                                                                     owl:onProperty <http://purl.obolibrary.org/obo/BFO_0000176> ;
                                                                                                     owl:someValuesFrom <http://purl.obolibrary.org/obo/ENVO_06105101>
                                                                                                   ]
                                                                                                 ) ;
                                                                              rdf:type owl:Class
                                                                            ]
                                                       ]
                                                     ) ;
                                  rdf:type owl:Class
                                ] ;
                <http://www.geneontology.org/formats/oboInOwl#hasExactSynonym> "plastic weathering"@en ;
                rdfs:comment """Definitions of plastic properties, such as biodegradability and composability, and related processes, currently covered in the ClimOO Ontology, refer to existing policy standards. This aims to stress the significance of such regulations concerning defining such entities and, especially, the consequences in terms of pollution and sustainability interventions.

It is noteworthy to mention that such standards present limitations. See, for instance, the work of Rayns et al. (2021), Steiner et al. (2022, 2024), concerning plastic biodegradability.

We envision implementing such definitions in accordance with regulation revisions and novel research findings."""@en ,
                             "Reference to specific types of degradation, such as photodegradation, oxidative degradation, photo-oxidative degradation, thermal degradation, thermochemical degradation, and thermo-oxidative degradation, can be added as needed."@en ;
                rdfs:label "plastic degradation"@en ;
                rdfs:seeAlso "http://purl.allotrope.org/ontologies/process#AFP_0003641" ;
                <http://www.w3.org/2004/02/skos/core#definition> "An process that leads some polymers constituting some plastic to vary their physical and chemical qualities due to interactions with factors such as heat, light, or chemical entities, resulting in a decrease in their molecular weight."@en ;
                <https://spec.industrialontologies.org/ontology/core/meta/AnnotationVocabulary/maturity> <https://spec.industrialontologies.org/ontology/core/meta/AnnotationVocabulary/Released> ;
                <https://www.w3id.org/sco#SCO_0000039> :ClimOO_0000072 ,
                                                       :ClimOO_0000073 ,
                                                       :ClimOO_0000074 ,
                                                       :ClimOO_0000075 ,
                                                       :ClimOO_0000228 .

[ rdf:type owl:Axiom ;
   owl:annotatedSource :ClimOO_0000168 ;
   owl:annotatedProperty <http://www.geneontology.org/formats/oboInOwl#hasExactSynonym> ;
   owl:annotatedTarget "plastic weathering"@en ;
   <https://spec.industrialontologies.org/ontology/core/meta/AnnotationVocabulary/maturity> <https://spec.industrialontologies.org/ontology/core/meta/AnnotationVocabulary/Provisional>
 ] .


###  https://www.w3id.org/climoo#ClimOO_0000169
:ClimOO_0000169 rdf:type owl:Class ;
                rdfs:subClassOf :ClimOO_0000225 ,
                                [ rdf:type owl:Restriction ;
                                  owl:onProperty <http://purl.obolibrary.org/obo/BFO_0000117> ;
                                  owl:someValuesFrom :ClimOO_0000168
                                ] ,
                                [ rdf:type owl:Restriction ;
                                  owl:onProperty <http://purl.obolibrary.org/obo/RO_0002233> ;
                                  owl:someValuesFrom <http://purl.obolibrary.org/obo/ENVO_01000776>
                                ] ;
                rdfs:comment """Definitions of plastic properties, such as biodegradability and composability, and related processes, currently covered in the ClimOO Ontology, refer to existing policy standards. This aims to stress the significance of such regulations concerning defining such entities and, especially, the consequences in terms of pollution and sustainability interventions.

It is noteworthy to mention that such standards present limitations. See, for instance, the work of Rayns et al. (2021), Steiner et al. (2022, 2024), concerning plastic biodegradability.

We envision implementing such definitions in accordance with regulation revisions and novel research findings."""@en ,
                             "Reference to specific types of plastic materials and items can be added as needed."@en ,
                             "The hierarchy position of this class is to be further discussed." ;
                rdfs:label "plastic fragmentation"@en ;
                <http://www.w3.org/2004/02/skos/core#definition> "A process that leads to breaking pieces of plastic down into pieces of a smaller size."@en ;
                <https://spec.industrialontologies.org/ontology/core/meta/AnnotationVocabulary/maturity> <https://spec.industrialontologies.org/ontology/core/meta/AnnotationVocabulary/Released> ;
                <https://www.w3id.org/sco#SCO_0000039> :ClimOO_0000072 ,
                                                       :ClimOO_0000073 ,
                                                       :ClimOO_0000074 ,
                                                       :ClimOO_0000075 ,
                                                       :ClimOO_0000228 .


###  https://www.w3id.org/climoo#ClimOO_0000170
:ClimOO_0000170 rdf:type owl:Class ;
                owl:equivalentClass [ owl:intersectionOf ( :ClimOO_0000139
                                                           [ rdf:type owl:Restriction ;
                                                             owl:onProperty <http://purl.obolibrary.org/obo/RO_0002233> ;
                                                             owl:someValuesFrom [ owl:intersectionOf ( <http://purl.obolibrary.org/obo/CHEBI_60027>

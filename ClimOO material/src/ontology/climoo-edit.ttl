###  https://www.w3id.org/climoo#ClimOO_0000229
:ClimOO_0000229 rdf:type owl:Class ;
                rdfs:subClassOf <https://www.commoncoreontologies.org/ont00000378> ;
                rdfs:comment """For insights on definitions, see, for instance:
https://www.merriam-webster.com/dictionary/transparent 
https://en.wikipedia.org/wiki/Transparency_and_translucency"""@en ,
                             "We include this class as a subclass of color for reasons of simplicity. We are aware that this is not an accurate representation of transparency and related optical properties. For ClimOO Ontology purposes, however, this is acceptable. Implementations will revise this class to establish an adequate representation."@en ;
                rdfs:label "transparent"@en ;
                <https://spec.industrialontologies.org/ontology/core/meta/AnnotationVocabulary/maturity> <https://spec.industrialontologies.org/ontology/core/meta/AnnotationVocabulary/Provisional> .


###  https://www.w3id.org/climoo#ClimOO_0000230
:ClimOO_0000230 rdf:type owl:Class ;
                rdfs:subClassOf :ClimOO_0000231 ;
                owl:disjointWith :ClimOO_0000232 ,
                                 :ClimOO_0000233 ;
                rdfs:comment """A possible way to align he two systems of classification concerning microplastic size ranges is to include a “large microplastic” class covering microplastic from 1 to 5 mm.
See, for instance, ISO/TR 21960:2020Plastics — Environmental aspects — State of knowledge and methodologies https://www.iso.org/standard/72300.html"""@en ;
                rdfs:label "microplastic particle - Hartmann et al. (2019) classification"@en ;
                <http://www.w3.org/2004/02/skos/core#definition> "A plastic debris particle that is between 1 and 1000 µm in its largest dimension."@en ;
                <https://spec.industrialontologies.org/ontology/core/meta/AnnotationVocabulary/maturity> <https://spec.industrialontologies.org/ontology/core/meta/AnnotationVocabulary/Released> ;
                <https://www.w3id.org/sco#SCO_0000039> :ClimOO_0000073 .


###  https://www.w3id.org/climoo#ClimOO_0000231
:ClimOO_0000231 rdf:type owl:Class ;
                rdfs:subClassOf :ClimOO_0000163 ;
                rdfs:comment "This class has only been created for grouping purposes. Do not use it directly."@en ,
                             "We included the double-inheritance axiom, even if it’s not the preferred practice, because some of these classes pertain to both classification systems."@en ;
                rdfs:label "plastic debris particle - Hartmann et al. (2019) size classification"@en ;
                <https://www.w3id.org/sco#SCO_0000039> :ClimOO_0000073 .


###  https://www.w3id.org/climoo#ClimOO_0000232
:ClimOO_0000232 rdf:type owl:Class ;
                rdfs:subClassOf :ClimOO_0000231 ;
                owl:disjointWith :ClimOO_0000233 ;
                rdfs:label "mesoplastic particle - Hartmann et al. (2019) classification"@en ;
                <http://www.w3.org/2004/02/skos/core#definition> "A plastic debris particle that is between 1 and 10 mm in its largest dimension."@en ;
                <https://spec.industrialontologies.org/ontology/core/meta/AnnotationVocabulary/maturity> <https://spec.industrialontologies.org/ontology/core/meta/AnnotationVocabulary/Released> ;
                <https://www.w3id.org/sco#SCO_0000039> :ClimOO_0000073 .


###  https://www.w3id.org/climoo#ClimOO_0000233
:ClimOO_0000233 rdf:type owl:Class ;
                rdfs:subClassOf :ClimOO_0000231 ;
                rdfs:comment "We included an upper-level threshold to completely define this class. We follow EnvO representation."@en ;
                rdfs:label "macroplastic particle - Hartmann et al. (2019) classification"@en ;
                <http://www.w3.org/2004/02/skos/core#definition> "A plastic debris particle that is between 1 cm and 1 m in its largest dimension."@en ;
                <https://spec.industrialontologies.org/ontology/core/meta/AnnotationVocabulary/maturity> <https://spec.industrialontologies.org/ontology/core/meta/AnnotationVocabulary/Released> ;
                <https://www.w3id.org/sco#SCO_0000039> :ClimOO_0000073 .


###  https://www.w3id.org/climoo#ClimOO_0000234
:ClimOO_0000234 rdf:type owl:Class ;
                rdfs:subClassOf :ClimOO_0000163 ;
                rdfs:comment "This class has only been created for grouping purposes. Do not use it directly."@en ,
                             "We included the double-inheritance axiom, even if it’s not the preferred practice, because some of these classes pertain to both classification systems."@en ;
                rdfs:label "plastic debris particle - EnvO size classification"@en ;
                <https://www.w3id.org/sco#SCO_0000039> :ClimOO_0000131 .


###  https://www.w3id.org/climoo#ClimOO_0000235
:ClimOO_0000235 rdf:type owl:Class ;
                rdfs:subClassOf <http://purl.obolibrary.org/obo/BFO_0000023> ;
                rdfs:comment """This class aims to be a generalization of the SuMSO \"product-role\" class, as for the \"waste-role\" and \"by-product-role\" classes. For a definition, see the SuMSO class, without considering references to supply chains.

See also: 
https://www.w3id.org/climoo#ClimOO_0000206
https://w3id.org/sumso#SuMSO_0000159
http://purl.obolibrary.org/obo/ENVO_01000665
https://w3id.org/sumso#SuMSO_0000160
https://w3id.org/sumso#SuMSO_0000053"""@en ;
                rdfs:label "product role"@en ;
                <https://spec.industrialontologies.org/ontology/core/meta/AnnotationVocabulary/adaptedFrom> <https://w3id.org/sumso#SuMSO_0000053> .



                                    ] ;
                rdfs:subClassOf <http://purl.obolibrary.org/obo/ENVO_01001646> ,
                                [ owl:intersectionOf ( <http://purl.obolibrary.org/obo/ENVO_01001646>
                                                       [ rdf:type owl:Restriction ;
                                                         owl:onProperty <http://purl.obolibrary.org/obo/RO_0002353> ;
                                                         owl:someValuesFrom :ClimOO_0000119
                                                       ]
                                                     ) ;
                                  rdf:type owl:Class
                                ] ;
                rdfs:label "compost"@en ;
                rdfs:seeAlso "http://purl.obolibrary.org/obo/ENVO_00002170" ;
                <http://www.w3.org/2004/02/skos/core#definition> "An amorphous solid (environmental material) that is obtained by composting organic wastes, generally composed of vegetable, fruit, and garden residues, sometimes with other organic materials. The input wastes contain a limited amount of minerals.  (See EU EN 13432, UNI EN ISO 20200, and Regulation - 2023/2055 - EN - EUR-Lex)."@en ;
                <https://spec.industrialontologies.org/ontology/core/meta/AnnotationVocabulary/maturity> <https://spec.industrialontologies.org/ontology/core/meta/AnnotationVocabulary/Released> .


###  https://www.w3id.org/climoo#ClimOO_0000115
:ClimOO_0000115 rdf:type owl:Class ;
                owl:equivalentClass [ owl:intersectionOf ( :ClimOO_0000104
                                                           [ rdf:type owl:Restriction ;
                                                             owl:onProperty <http://purl.obolibrary.org/obo/BFO_0000054> ;
                                                             owl:someValuesFrom :ClimOO_0000119
                                                           ]
                                                           [ rdf:type owl:Restriction ;
                                                             owl:onProperty <http://purl.obolibrary.org/obo/BFO_0000054> ;
                                                             owl:allValuesFrom :ClimOO_0000119
                                                           ]
                                                         ) ;
                                      rdf:type owl:Class
                                    ] ;
                rdfs:subClassOf :ClimOO_0000104 ,
                                [ rdf:type owl:Restriction ;
                                  owl:onProperty <http://purl.obolibrary.org/obo/BFO_0000054> ;
                                  owl:someValuesFrom :ClimOO_0000119
                                ] ;
                rdfs:comment "A biodegradability disposition whose realization leads an environmental material to biodegrade while participating in a composting process."@en ,
                             """Definitions of plastic properties, such as biodegradability and composability, and related processes, currently covered in the ClimOO Ontology, refer to existing policy standards. This aims to stress the significance of such regulations concerning defining such entities and, especially, the consequences in terms of pollution and sustainability interventions.

It is noteworthy to mention that such standards present limitations. See, for instance, the work of Rayns et al. (2021), Steiner et al. (2022, 2024), concerning plastic biodegradability.

We envision implementing such definitions in accordance with regulation revisions and novel research findings."""@en ;
                rdfs:label "compostability"@en ;
                <https://spec.industrialontologies.org/ontology/core/meta/AnnotationVocabulary/maturity> <https://spec.industrialontologies.org/ontology/core/meta/AnnotationVocabulary/Released> ;
                <https://www.w3id.org/sco#SCO_0000039> :ClimOO_0000072 ,
                                                       :ClimOO_0000073 ,
                                                       :ClimOO_0000074 ,
                                                       :ClimOO_0000075 ,
                                                       :ClimOO_0000228 .



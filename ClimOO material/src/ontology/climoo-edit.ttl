###  http://purl.obolibrary.org/obo/ENVO_06105014
<http://purl.obolibrary.org/obo/ENVO_06105014> rdfs:subClassOf [ owl:intersectionOf ( :ClimOO_0000225
                                                                                      [ rdf:type owl:Restriction ;
                                                                                        owl:onProperty <http://purl.obolibrary.org/obo/BFO_0000055> ;
                                                                                        owl:someValuesFrom :ClimOO_0000104
                                                                                      ]
                                                                                    ) ;
                                                                 rdf:type owl:Class
                                                               ] ,
                                                               [ rdf:type owl:Restriction ;
                                                                 owl:onProperty <http://purl.obolibrary.org/obo/BFO_0000057> ;
                                                                 owl:someValuesFrom <http://purl.obolibrary.org/obo/PCO_0000031>
                                                               ] ;
                                               <http://www.ontologyrepository.com/CommonCoreOntologies/definition> """ClimOO Ontology revised definition:
A transformation process, mainly driven by biological entities (no humans), that leads some material entity vary their physical and chemical qualities, resulting in a decrease in their molecular weight."""@en ;
                                               rdfs:comment """ClimOO Ontology developer comment:
Definitions of plastic properties, such as biodegradability and composability, and related processes, currently covered in the ClimOO Ontology, refer to existing policy standards. This aims to stress the significance of such regulations concerning defining such entities and, especially, the consequences in terms of pollution and sustainability interventions.

It is noteworthy to mention that such standards present limitations. See, for instance, the work of Rayns et al. (2021), Steiner et al. (2022, 2024), concerning plastic biodegradability.

We envision implementing such definitions in accordance with regulation revisions and novel research findings."""@en .


###  http://purl.obolibrary.org/obo/ENVO_06105015
<http://purl.obolibrary.org/obo/ENVO_06105015> owl:equivalentClass [ owl:intersectionOf ( :ClimOO_0000180
                                                                                          [ rdf:type owl:Restriction ;
                                                                                            owl:onProperty <http://purl.obolibrary.org/obo/RO_0002233> ;
                                                                                            owl:someValuesFrom [ owl:intersectionOf ( :ClimOO_0000109
                                                                                                                                      [ rdf:type owl:Restriction ;
                                                                                                                                        owl:onProperty <http://purl.obolibrary.org/obo/BFO_0000176> ;
                                                                                                                                        owl:someValuesFrom :ClimOO_0000107
                                                                                                                                      ]
                                                                                                                                    ) ;
                                                                                                                 rdf:type owl:Class
                                                                                                               ]
                                                                                          ]
                                                                                        ) ;
                                                                     rdf:type owl:Class
                                                                   ] ;
                                               rdfs:subClassOf [ owl:intersectionOf ( :ClimOO_0000168
                                                                                      [ rdf:type owl:Restriction ;
                                                                                        owl:onProperty <http://purl.obolibrary.org/obo/RO_0002233> ;
                                                                                        owl:someValuesFrom [ owl:intersectionOf ( :ClimOO_0000109
                                                                                                                                  [ rdf:type owl:Restriction ;
                                                                                                                                    owl:onProperty <http://purl.obolibrary.org/obo/BFO_0000176> ;
                                                                                                                                    owl:someValuesFrom :ClimOO_0000107
                                                                                                                                  ]
                                                                                                                                ) ;
                                                                                                             rdf:type owl:Class
                                                                                                           ]
                                                                                      ]
                                                                                    ) ;
                                                                 rdf:type owl:Class
                                                               ] ;
                                               <http://www.geneontology.org/formats/oboInOwl#hasExactSynonym> "biological plastic degradation, biogical degradation of plastic"@en ;
                                               rdfs:comment """ClimOO Ontology developer comment:
To date, the ClimOO ontology does not restrict such classes to solely refer to wasted plastics. Implementations may extend the current representation in such a direction, if needed. The only exception is the “plastic composting process” class, given that the aimed specific focus on composting of waste plastics."""@en ,
                                                            """ClimOO Ontology developer comment:
We primarily focused on biodegradability in relation to synthetic plastics, related polymers and items. Reference to biodegradability concerning plastics more in general, for instance in relation to natural plastics, or in relation to polymer-based materials can be added as needed."""@en ;
                                               rdfs:label """Revised definition for ClimOO Ontology:
A polymer biodegradation that applies to some polymers constituting some plastic (biodegradable plastic).""" .


###  http://purl.obolibrary.org/obo/ENVO_06105101
<http://purl.obolibrary.org/obo/ENVO_06105101> rdfs:subClassOf _:genid217 ,
                                                               [ owl:intersectionOf ( [ rdf:type owl:Restriction ;
                                                                                        owl:onProperty <http://purl.obolibrary.org/obo/RO_0000086> ;
                                                                                        owl:someValuesFrom <http://purl.obolibrary.org/obo/PATO_0000117>
                                                                                      ]
                                                                                      [ rdf:type owl:Restriction ;
                                                                                        owl:onProperty <http://purl.obolibrary.org/obo/RO_0000086> ;
                                                                                        owl:someValuesFrom [ rdf:type owl:Class ;
                                                                                                             owl:unionOf ( <http://purl.obolibrary.org/obo/PATO_0000141>
                                                                                                                           <http://purl.obolibrary.org/obo/PATO_0001332>
                                                                                                                         )
                                                                                                           ]
                                                                                      ]
                                                                                    ) ;
                                                                 rdf:type owl:Class
                                                               ] ,
                                                               _:genid237 ,
                                                               [ rdf:type owl:Restriction ;
                                                                 owl:onProperty <http://purl.obolibrary.org/obo/RO_0000091> ;
                                                                 owl:someValuesFrom <https://www.commoncoreontologies.org/ont00000378>
                                                               ] ;
                                               <http://www.geneontology.org/formats/oboInOwl#hasRelatedSynonym> "plastic polymer, polymer, plastic polymer mixture"@en ;
                                               rdfs:comment """ClimOO Ontology developer comment:
ClimOO Ontology does currently not delve into representing semicrystalline, semicrystalline, wax-like, and semisolid polymer-based materials, such as polymer gels. Future work may implement the representation of plastics and polymers in such a direction, as needed."""@en ,
                                                            """ClimOO Ontology developer comment:
From a material science perspective (which is the one we have to refer to for classifying plastics and polymers) plastic materials are constituted by polymers that are thermosetting and thermoplastic, and not, for instance, by elastic polymers. There exist, however, some synthetic combinations, such as thermoplastic elastomer-based synthetic materials, that are composed by polymers presenting both elastic and plastic properties. Strictly speaking, the last are not plastics (material science perspective). However, these materials are included in the count of debris (from an environmental perspective which is the one we have to refer to for classifying debris and pollution). So, the ClimOO Ontology accounts for these two perspectives, modeling differences and interconnection."""@en ,
                                                            """ClimOO Ontology developer comment:
Implementations require to address references to composition threshold. We envision discussion with subject matter experts."""@en ,
                                                            """ClimOO Ontology developer comment:
This class and related subclasses refer to the actual plastic materials, not the polymers composing it neither the pieces of plastic or object composed by those materials. This is in compliance with the literature and with EnvO approach.

The ClimOO Ontology distinguishes among the actual polymers (plastic polymers), the materials made of such polymers + additives etc. (plastic materials), and the objects/debris made of such plastic materials (pieces of plastic, and plastic litters)."""@en ,
                                                            """ClimOO Ontology developer comment:
We primarily focused on synthetic plastics, related polymers, and items for domain representation purposes. However, we equally ensured adequate representations of distinctions and relations with other types of plastics, e.g. natural plastics, and polymer-based materials (and related polymers and items)."""@en ;
                                               <http://www.w3.org/2004/02/skos/core#definition> """ClimOO Ontology revised definition:
An environmental material which is composed of thermoplastic and thermosetting polymers with high molecular mass."""@en ;
                                               <https://www.w3id.org/sco#SCO_0000039> :ClimOO_0000072 ,
                                                                                      :ClimOO_0000073 ,
                                                                                      :ClimOO_0000074 ,
                                                                                      :ClimOO_0000075 .

_:genid217 owl:intersectionOf ( [ rdf:type owl:Restriction ;
                                   owl:onProperty <http://purl.obolibrary.org/obo/BFO_0000110> ;
                                   owl:someValuesFrom [ rdf:type owl:Class ;
                                                        owl:unionOf ( :ClimOO_0000217
                                                                      :ClimOO_0000218
                                                                    )
                                                      ]
                                 ]
                                 [ rdf:type owl:Restriction ;
                                   owl:onProperty <http://purl.obolibrary.org/obo/BFO_0000110> ;
                                   owl:allValuesFrom [ rdf:type owl:Class ;
                                                       owl:unionOf ( :ClimOO_0000217
                                                                     :ClimOO_0000218
                                                                   )
                                                     ]
                                 ]
                               ) ;
            rdf:type owl:Class .

_:genid237 rdf:type owl:Restriction ;
            owl:onProperty <http://purl.obolibrary.org/obo/RO_0000086> ;
            owl:someValuesFrom <http://purl.obolibrary.org/obo/PATO_0000125> .

[ rdf:type owl:Axiom ;
   owl:annotatedSource <http://purl.obolibrary.org/obo/ENVO_06105101> ;
   owl:annotatedProperty rdfs:subClassOf ;
   owl:annotatedTarget _:genid217 ;
   rdfs:comment "BFO “continuant part” is not a transitive object property. User may incorporate transitivity to specify the chain of composition between polymers, plastic/polymers-based material, and related pieces and objects of plastic/polymers-based material, as needed."@en
 ] .

[ rdf:type owl:Axiom ;
   owl:annotatedSource <http://purl.obolibrary.org/obo/ENVO_06105101> ;
   owl:annotatedProperty rdfs:subClassOf ;
   owl:annotatedTarget _:genid237 ;
   rdfs:comment """ClimOO Ontology developer comment:
Reference to weight can be added as needed."""@en
 ] .



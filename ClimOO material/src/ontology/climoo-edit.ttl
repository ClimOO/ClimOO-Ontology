###  https://www.w3id.org/climoo#ClimOO_0000161
:ClimOO_0000161 rdf:type owl:Class ;
                rdfs:subClassOf :ClimOO_0000225 ,
                                [ owl:intersectionOf ( :ClimOO_0000225
                                                       [ rdf:type owl:Restriction ;
                                                         owl:onProperty <http://purl.obolibrary.org/obo/RO_0002233> ;
                                                         owl:someValuesFrom [ owl:intersectionOf ( :ClimOO_0000210
                                                                                                   [ rdf:type owl:Restriction ;
                                                                                                     owl:onProperty <http://purl.obolibrary.org/obo/BFO_0000176> ;
                                                                                                     owl:someValuesFrom :ClimOO_0000163
                                                                                                   ]
                                                                                                 ) ;
                                                                              rdf:type owl:Class
                                                                            ]
                                                       ]
                                                     ) ;
                                  rdf:type owl:Class
                                ] ;
                rdfs:comment """Definitions of plastic properties, such as biodegradability and composability, and related processes, currently covered in the ClimOO Ontology, refer to existing policy standards. This aims to stress the significance of such regulations concerning defining such entities and, especially, the consequences in terms of pollution and sustainability interventions.

It is noteworthy to mention that such standards present limitations. See, for instance, the work of Rayns et al. (2021), Steiner et al. (2022, 2024), concerning plastic biodegradability.

We envision implementing such definitions in accordance with regulation revisions and novel research findings."""@en ,
                             "Reference to specific types of degradation, such as photodegradation, oxidative degradation, photo-oxidative degradation, thermal degradation, thermochemical degradation, and thermo-oxidative degradation, can be added as needed."@en ;
                rdfs:label "plastic debris degradation"@en ;
                <http://www.w3.org/2004/02/skos/core#definition> "An process that leads some polymers constituting some plastic debris to vary their physical and chemical qualities due to interactions with factors such as heat, light, or chemical entities, resulting in a decrease in their molecular weight."@en ;
                <https://spec.industrialontologies.org/ontology/core/meta/AnnotationVocabulary/maturity> <https://spec.industrialontologies.org/ontology/core/meta/AnnotationVocabulary/Released> ;
                <https://www.w3id.org/sco#SCO_0000039> :ClimOO_0000072 ,
                                                       :ClimOO_0000073 ,
                                                       :ClimOO_0000074 ,
                                                       :ClimOO_0000075 ,
                                                       :ClimOO_0000228 .


###  https://www.w3id.org/climoo#ClimOO_0000162
:ClimOO_0000162 rdf:type owl:Class ;
                rdfs:subClassOf :ClimOO_0000128 ,
                                [ rdf:type owl:Restriction ;
                                  owl:onProperty <http://purl.obolibrary.org/obo/BFO_0000117> ;
                                  owl:someValuesFrom :ClimOO_0000161
                                ] ,
                                _:genid1352 ,
                                [ rdf:type owl:Restriction ;
                                  owl:onProperty <http://purl.obolibrary.org/obo/RO_0002233> ;
                                  owl:someValuesFrom :ClimOO_0000163
                                ] ,
                                [ rdf:type owl:Restriction ;
                                  owl:onProperty <http://purl.obolibrary.org/obo/RO_0002427> ;
                                  owl:someValuesFrom <http://purl.obolibrary.org/obo/ENVO_02500040>
                                ] ;
                rdfs:label "plastic debris fragmentation"@en ;
                <http://www.w3.org/2004/02/skos/core#definition> "A fragmentation of a piece of synthetic polymer-based material process that leads to breaking pieces of plastic debris down into pieces of a smaller size."@en ;
                <https://spec.industrialontologies.org/ontology/core/meta/AnnotationVocabulary/maturity> <https://spec.industrialontologies.org/ontology/core/meta/AnnotationVocabulary/Released> ;
                <https://www.w3id.org/sco#SCO_0000039> :ClimOO_0000072 ,
                                                       :ClimOO_0000073 ,

[ rdf:type owl:Axiom ;
   owl:annotatedSource :ClimOO_0000237 ;
   owl:annotatedProperty owl:equivalentClass ;
   owl:annotatedTarget _:genid1859 ;
   rdfs:comment "We currently include a reference to the two systems of classification covered by the ClimOO Ontology, concerning microplastic debris. We envision revisions of this axiom following the inclusion of further systems of classification."@en
 ] .


###  https://www.w3id.org/climoo#ClimOO_0000238
:ClimOO_0000238 rdf:type owl:Class ;
                rdfs:subClassOf :ClimOO_0000179 ,
                                _:genid1890 ;
                rdfs:label "plastic pollution prevention"@en ;
                <http://www.w3.org/2004/02/skos/core#definition> "A pollution prevention process that leads to avoiding the release and accumulation of plastic debris particles in an environmental material, according to some stakeholder goals and perspectives."@en ;
                <https://spec.industrialontologies.org/ontology/core/meta/AnnotationVocabulary/maturity> <https://spec.industrialontologies.org/ontology/core/meta/AnnotationVocabulary/Released> .

_:genid1890 rdf:type owl:Restriction ;
             owl:onProperty <http://purl.obolibrary.org/obo/RO_0002212> ;
             owl:someValuesFrom <http://purl.obolibrary.org/obo/ENVO_02500040> .

[ rdf:type owl:Axiom ;
   owl:annotatedSource :ClimOO_0000238 ;
   owl:annotatedProperty rdfs:subClassOf ;
   owl:annotatedTarget _:genid1890 ;
   rdfs:comment "Currently, the axiomatization of this class covers reference to the RO “negatively regulates” object property. Revisions may provide this axiom with more specific and suitable object properties."@en
 ] .


###  https://www.w3id.org/climoo#ClimOO_0000239
:ClimOO_0000239 rdf:type owl:Class ;
                rdfs:subClassOf :ClimOO_0000105 ,
                                [ rdf:type owl:Restriction ;
                                  owl:onProperty <http://purl.obolibrary.org/obo/BFO_0000058> ;
                                  owl:someValuesFrom :ClimOO_0000240
                                ] ;
                rdfs:label "compostable - claim"@en ;
                <http://www.w3.org/2004/02/skos/core#definition> "A compostable claim that is concretized by some compostable composition quality and describes such composition quality."@en ;
                <https://spec.industrialontologies.org/ontology/core/meta/AnnotationVocabulary/maturity> <https://spec.industrialontologies.org/ontology/core/meta/AnnotationVocabulary/Released> .


###  https://www.w3id.org/climoo#ClimOO_0000240
:ClimOO_0000240 rdf:type owl:Class ;
                rdfs:subClassOf :ClimOO_0000106 ;
                rdfs:label "compostable composition"@en ;
                <http://www.w3.org/2004/02/skos/core#definition> "A biodegradable composition that inheres in a bearer in virtue of being primarily composed of (or being primarily composed by a material that is primarily composed of) polymers that can degradate in a composting process."@en ;
                <https://spec.industrialontologies.org/ontology/core/meta/AnnotationVocabulary/maturity> <https://spec.industrialontologies.org/ontology/core/meta/AnnotationVocabulary/Released> .


###  https://www.w3id.org/climoo#ClimOO_0000241
:ClimOO_0000241 rdf:type owl:Class ;
                rdfs:subClassOf <http://purl.obolibrary.org/obo/BFO_0000016> ;
                rdfs:comment "Reference to corresponding motion processes can be added as needed."@en ;
                rdfs:label "disposition to motion in the environment"@en ;
                <http://www.w3.org/2004/02/skos/core#definition> "A disposition that realizes in a bearer when participating in a process of motion that occurs in an environmental system/environmental system environment."@en ;
                <https://spec.industrialontologies.org/ontology/core/meta/AnnotationVocabulary/maturity> <https://spec.industrialontologies.org/ontology/core/meta/AnnotationVocabulary/Released> .



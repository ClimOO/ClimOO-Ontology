###  https://www.w3id.org/climoo#ClimOO_0000072
:ClimOO_0000072 rdf:type owl:NamedIndividual ,
                         :ClimOO_0000093 ;
                <http://purl.org/dc/terms/description> "This owl:NamedIndividual tracks the perspectives of ClimOO project participants according to which this ontology has been built."@en ;

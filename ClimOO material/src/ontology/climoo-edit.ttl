                                  ]
                                  [ rdf:type owl:Restriction ;
                                    owl:onProperty <http://purl.obolibrary.org/obo/RO_0000091> ;
                                    owl:someValuesFrom :ClimOO_0000241
                                  ]
                                  [ rdf:type owl:Restriction ;
                                    owl:onProperty <http://purl.obolibrary.org/obo/RO_0000091> ;
                                    owl:someValuesFrom [ rdf:type owl:Class ;
                                                         owl:complementOf :ClimOO_0000224
                                                       ]
                                  ]
                                ) ;
             rdf:type owl:Class .

_:genid1378 owl:intersectionOf ( <http://purl.obolibrary.org/obo/ENVO_01001687>
                                  [ rdf:type owl:Class ;
                                    owl:complementOf [ rdf:type owl:Restriction ;
                                                       owl:onProperty <http://purl.obolibrary.org/obo/RO_0000085> ;
                                                       owl:someValuesFrom [ owl:intersectionOf ( <http://purl.obolibrary.org/obo/BFO_0000034>
                                                                                                 [ rdf:type owl:Restriction ;
                                                                                                   owl:onProperty <http://purl.obolibrary.org/obo/BFO_0000054> ;

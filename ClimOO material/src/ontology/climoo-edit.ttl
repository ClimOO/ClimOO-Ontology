                                  owl:onProperty <http://purl.obolibrary.org/obo/RO_0002233> ;
                                  owl:someValuesFrom :ClimOO_0000153
                                ] ;
                rdfs:comment "We currently focus this class on pieces of synthetic plastic. Implementations will expand current representations to plastic materials and polymers. Also, reference to the combustion of pieces of synthetic polymer-based materials can be included, as needed."@en ;
                rdfs:label "plastic combustion"@en ;
                <http://www.w3.org/2004/02/skos/core#definition> "An exothermic chemical reaction process between some plastic and an oxidant (usually oxygen), which is sometimes accompanied by the production of light."@en ;
                <https://spec.industrialontologies.org/ontology/core/meta/AnnotationVocabulary/adaptedFrom> "http://purl.obolibrary.org/obo/CHMO_0001473" ;
                <https://spec.industrialontologies.org/ontology/core/meta/AnnotationVocabulary/maturity> <https://spec.industrialontologies.org/ontology/core/meta/AnnotationVocabulary/Released> .



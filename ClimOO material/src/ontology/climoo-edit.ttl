###  https://www.w3id.org/climoo#ClimOO_0000172
:ClimOO_0000172 rdf:type owl:Class ;
                rdfs:subClassOf :ClimOO_0000226 ,
                                [ rdf:type owl:Restriction ;
                                  owl:onProperty <http://purl.obolibrary.org/obo/RO_0004008> ;
                                  owl:someValuesFrom :ClimOO_0000171
                                ] ;
                <http://www.geneontology.org/formats/oboInOwl#hasExactSynonym> "plastic object production"@en ;
                rdfs:comment "References to manufacturing processes of plastic objects made of specific type of plastics, such as recycled, virgin, biobased, and biodegradable can be added as needed."@en ;
                rdfs:label "plastic object manufacturing process"@en ;

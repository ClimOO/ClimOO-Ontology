###  http://purl.obolibrary.org/obo/RO_0002090
obo:RO_0002090 rdf:type owl:ObjectProperty ;
               rdfs:subPropertyOf obo:BFO_0000063 ;
               obo:IAO_0000117 <https://orcid.org/0000-0002-7073-9172> ;
               obo:IAO_0000118 "ends_at_start_of" ,
                               "meets" ;

               rdfs:label "determines" .


###  http://purl.obolibrary.org/obo/RO_0002509
obo:RO_0002509 rdf:type owl:ObjectProperty ;
               rdfs:subPropertyOf obo:RO_0002131 ,
                                  obo:RO_0002506 ;

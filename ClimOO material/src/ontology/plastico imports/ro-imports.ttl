obo:RO_0002087 rdf:type owl:ObjectProperty ;
               rdfs:subPropertyOf obo:BFO_0000062 ;
               obo:IAO_0000117 <https://orcid.org/0000-0002-7073-9172> ;
               obo:IAO_0000118 "starts_at_end_of" ;
               obo:IAO_0000412 obo:ro.owl ;

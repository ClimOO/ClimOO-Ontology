obo:RO_0002508 rdf:type owl:ObjectProperty ;
               rdfs:subPropertyOf obo:RO_0002566 ;
               obo:IAO_0000115 "inverse of determined by" ;
               obo:IAO_0000117 <https://orcid.org/0000-0002-6601-2165> ;

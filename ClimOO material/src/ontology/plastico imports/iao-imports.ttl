                                             rdfs:comment """This file contains ClimOO Ontology imports from the Information Artifact Ontology (IAO). Imports were manually collected and revised.

Ontology source: IAO 2022-11-07
https://github.com/information-artifact-ontology/IAO/releases/tag/v2022-11-07"""@en ;
                                             rdfs:seeAlso "https://github.com/information-artifact-ontology/IAO" ;
                                             owl:versionInfo "2025-06-18" .


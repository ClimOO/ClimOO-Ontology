                                           "pellet de plástico"@es ,
                                           "pellet di plastica"@it ,
                                           "resin bead"@en ;
                  oboInOwl:inSubset "envoPlastics"@en ;
                  rdfs:label "plastic pellet"@en .


###  http://purl.obolibrary.org/obo/ENVO_06105026
obo:ENVO_06105026 rdf:type owl:Class ;
                  rdfs:subClassOf obo:ENVO_06105006 ;
                  obo:IAO_0000115 "A piece of plastic foam which has a near-spherical or granular shape."@en ;
                  obo:IAO_0000412 obo:envo.owl ;

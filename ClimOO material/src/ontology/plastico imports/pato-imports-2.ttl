    <!-- http://purl.obolibrary.org/obo/PATO_0001199 -->

    <owl:Class rdf:about="http://purl.obolibrary.org/obo/PATO_0001199">
        <rdfs:subClassOf rdf:resource="http://purl.obolibrary.org/obo/PATO_0000052"/>

        <owl:annotatedSource rdf:resource="http://purl.obolibrary.org/obo/PATO_0000918"/>
        <owl:annotatedProperty rdf:resource="http://purl.obolibrary.org/obo/IAO_0000115"/>
        <owl:annotatedTarget>A 3-D extent quality inhering in a bearer by virtue of the bearer&apos;s amount of 3-dimensional space it occupies.</owl:annotatedTarget>
        <oboInOwl:hasDbXref>PATOC:GVG</oboInOwl:hasDbXref>
    </owl:Axiom>
    


    <!-- http://purl.obolibrary.org/obo/PATO_0000947 -->

    <owl:Class rdf:about="http://purl.obolibrary.org/obo/PATO_0000947">
        <rdfs:subClassOf rdf:resource="http://purl.obolibrary.org/obo/PATO_0002318"/>
        <obo:IAO_0000115>A spheroid quality inhering in a bearer by virtue of the bearer&apos;s being oval with two axes of symmetry, as produced by a conical section.</obo:IAO_0000115>
        <oboInOwl:hasExactSynonym>ellipse-shaped</oboInOwl:hasExactSynonym>
        <oboInOwl:hasExactSynonym>ellipsoid</oboInOwl:hasExactSynonym>
        <oboInOwl:hasExactSynonym>elliptical</oboInOwl:hasExactSynonym>
        <oboInOwl:hasOBONamespace>quality</oboInOwl:hasOBONamespace>
        <oboInOwl:hasRelatedSynonym>oval</oboInOwl:hasRelatedSynonym>
        <oboInOwl:hasRelatedSynonym>ovoid</oboInOwl:hasRelatedSynonym>
        <oboInOwl:id>PATO:0000947</oboInOwl:id>
        <oboInOwl:inSubset rdf:resource="http://purl.obolibrary.org/obo/pato#cell_quality"/>
        <oboInOwl:inSubset rdf:resource="http://purl.obolibrary.org/obo/pato#mpath_slim"/>
        <oboInOwl:inSubset rdf:resource="http://purl.obolibrary.org/obo/pato#value_slim"/>
        <rdfs:label>elliptic</rdfs:label>
    </owl:Class>
    <owl:Axiom>
        <owl:annotatedSource rdf:resource="http://purl.obolibrary.org/obo/PATO_0000947"/>
        <owl:annotatedProperty rdf:resource="http://purl.obolibrary.org/obo/IAO_0000115"/>
        <owl:annotatedTarget>A spheroid quality inhering in a bearer by virtue of the bearer&apos;s being oval with two axes of symmetry, as produced by a conical section.</owl:annotatedTarget>
        <oboInOwl:hasDbXref>PATOC:GVG</oboInOwl:hasDbXref>
    </owl:Axiom>
    


    <!-- http://purl.obolibrary.org/obo/PATO_0001018 -->

    <owl:Class rdf:about="http://purl.obolibrary.org/obo/PATO_0001018">

    <!-- http://purl.obolibrary.org/obo/PATO_0002226 -->

    <owl:Class rdf:about="http://purl.obolibrary.org/obo/PATO_0002226">
        <rdfs:subClassOf rdf:resource="http://purl.obolibrary.org/obo/PATO_0001873"/>
        <obo:IAO_0000115>A cylindrical shape quality inhering in a bearer by virtue of the bearer&apos;s being imperfectly cylindrical or approximately cylindrical.</obo:IAO_0000115>

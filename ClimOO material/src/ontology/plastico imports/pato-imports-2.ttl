    <owl:Class rdf:about="http://purl.obolibrary.org/obo/PATO_0001241"/>
    


    <!-- http://purl.obolibrary.org/obo/PATO_0001323 -->

    <owl:Class rdf:about="http://purl.obolibrary.org/obo/PATO_0001323">
        <rdfs:subClassOf rdf:resource="http://purl.obolibrary.org/obo/PATO_0001709"/>
        <obo:IAO_0000115>A 2-D extent quality inhering in a bearer by virtue of the bearer&apos;s two dimensional extent.</obo:IAO_0000115>
